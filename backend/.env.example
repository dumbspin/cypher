# Backend Environment Variables
# Copy this to .env and fill in your values

# Upstash Redis (get from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Google Safe Browsing API key (get free from https://developers.google.com/safe-browsing)
# Leave blank to skip Stage 1 — the scanner still uses PhishDestroy + OpenPhish.
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key

# PhishDestroy — NO API key required (Stage 2 runs automatically)

# ScreenshotOne API Key (get from https://screenshotone.com)
SCREENSHOTONE_API_KEY=your_screenshotone_api_key

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL_SECONDS=3600

# Your Vercel frontend URL (used for CORS — no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Rate limiting (requests per minute per IP)
RATE_LIMIT=10
